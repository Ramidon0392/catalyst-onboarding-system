# Catalyst Onboarding System — required environment variables
# Copy this file to config/.env (or project root .env) and fill in real values.
# NEVER commit a file containing real credential values.

# Airtable / Notion CRM
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_LEADS_TABLE_ID=
AIRTABLE_WORKFLOW_STATUS_TABLE_ID=
AIRTABLE_ERROR_LOG_TABLE_ID=

# Automation Engine (Zapier / Make.com)
AUTOMATION_ENGINE_WEBHOOK_URL=
AUTOMATION_ENGINE_API_KEY=

# Email / Calendar
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=
CONSULTATION_URL=
ADVISOR_EMAIL=

# Reporting (Google Sheets)
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Admin notifications
ADMIN_EMAIL=
